{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"machine_shape":"hm","gpuType":"T4","authorship_tag":"ABX9TyO5nYWWYy0a5gLt52ZhjsKh"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"},"accelerator":"GPU"},"cells":[{"cell_type":"code","source":["import os\n","import openai\n","import gradio as gr\n","import pandas as pd\n","import re\n","import base64\n","from io import BytesIO\n","from PIL import Image\n","from dotenv import load_dotenv\n","from google.colab import drive\n","import tensorflow as tf\n","import numpy as np\n","import requests\n","from io import BytesIO\n","import openai\n","import os\n","\n","# --- Conexión a Drive ---\n","from google.colab import drive\n","drive.mount('/content/drive')\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"itcOy8FZN6wT","executionInfo":{"status":"ok","timestamp":1774551020846,"user_tz":-60,"elapsed":88796,"user":{"displayName":"David Arenas","userId":"06929154522958225556"}},"outputId":"b9eaa5ff-602b-45ea-8f9d-d5b37e2fa366"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","source":["# --- CONFIGURACIÓN ---\n","# 1. Rutas y Claves (Ajusta esto)\n","MODEL_PATH = \"/content/drive/MyDrive/PROYECTI/modelo_infiltracion_final.h5\"  # Asegúrate de que este archivo exista\n","class_names = ['Infiltracion', 'Sano']   # El orden debe coincidir con tu modelo\n","\n","#Configuracion de seguridad del API_KEY\n","env_path = '/content/drive/MyDrive/PROYECTI/API_KEY.env'\n","\n","if os.path.exists(env_path):\n","\n","  load_dotenv(env_path)\n","  openai.api_key = os.getenv(\"API_KEY\")\n","  print(\"✅ API Key cargada correctamente.\")\n","\n","else:\n","  print(\"❌ No se encontró el archivo .env.\")\n","\n","\n","# 2. Cargar el Modelo CNN (Se hace una sola vez al inicio)\n","print(\"Cargando modelo CNN...\")\n","try:\n","    model = tf.keras.models.load_model(MODEL_PATH)\n","    print(\"Modelo cargado correctamente.\")\n","except Exception as e:\n","    print(f\"Error al cargar el modelo: {e}\")\n","    model = None"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"R9GYi1Xrd9CH","executionInfo":{"status":"ok","timestamp":1774552541437,"user_tz":-60,"elapsed":1037,"user":{"displayName":"David Arenas","userId":"06929154522958225556"}},"outputId":"3be18eaf-e10e-48de-9c03-ff7f5d7794b7"},"execution_count":19,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ API Key cargada correctamente.\n","Cargando modelo CNN...\n"]},{"output_type":"stream","name":"stderr","text":["WARNING:absl:Compiled the loaded model, but the compiled metrics have yet to be built. `model.compile_metrics` will be empty until you train or evaluate the model.\n"]},{"output_type":"stream","name":"stdout","text":["Modelo cargado correctamente.\n"]}]},{"cell_type":"code","source":["# ==========================================\n","# 2. FUNCIONES DE APOYO\n","# ==========================================\n","IMG_SIZE = (224, 224)\n","\n","def preprocesar_imagen(pil_img):\n","    \"\"\"Prepara la imagen para la CNN binaria.\"\"\"\n","    img = pil_img.convert('RGB')\n","    img = img.resize(IMG_SIZE)\n","    img_array = tf.keras.utils.img_to_array(img)\n","    img_array = np.expand_dims(img_array, axis=0)\n","    return img_array / 255.0\n","\n","def obtener_explicacion_llm(diagnostico):\n","    \"\"\"Lógica de prompt solicitada.\"\"\"\n","    if diagnostico == \"Sano\":\n","        return \"El pulmón está sano.\"\n","\n","    prompt = f\"El resultado de la CNN es Infiltración. Explica brevemente qué es esta enfermedad de forma clara.\"\n","    try:\n","        client = openai.OpenAI(api_key= os.getenv(\"API_KEY\"))\n","        response = client.chat.completions.create(\n","            model=\"gpt-3.5-turbo\",\n","            messages=[{\"role\": \"user\", \"content\": prompt}]\n","        )\n","        return response.choices[0].message.content\n","    except:\n","        return \"Infiltración: Acumulación de sustancias (líquido, células) en los pulmones.\"\n","\n","# ==========================================\n","# 3. MOTOR DE PREDICCIÓN (LOGICA DE UMBRAL 30%)\n","# ==========================================\n","\n","def motor_prediccion(img_input, id_input, url_input):\n","    if model is None:\n","        return None, {}, \"❌ Modelo no cargado.\"\n","\n","    try:\n","        # A. Cargar Imagen\n","        if url_input and url_input.strip():\n","            resp = requests.get(url_input, timeout=5)\n","            img_final = Image.open(BytesIO(resp.content))\n","        elif img_input is not None:\n","            img_final = img_input\n","        else:\n","            return None, {}, \"⚠️ Sube una imagen o URL.\"\n","\n","        # B. Predicción CNN\n","        img_ready = preprocesar_imagen(img_final)\n","        preds = model.predict(img_ready)\n","        valor = float(preds[0][0]) # Valor crudo de la red (0 a 1)\n","\n","        # C. LOGICA DE UMBRAL (THRESHOLD) AL 30%\n","        # Asumiendo que el valor bajo (cercano a 0) es Infiltración\n","        # Si el modelo arroja que la probabilidad de Infiltración es > 0.30:\n","\n","        prob_infil = 1 - valor  # Calculamos la probabilidad de infiltración\n","        prob_sano = valor\n","\n","        # --- NUEVA CONDICIÓN SOLICITADA ---\n","        if prob_infil > 0.30:\n","            resultado_texto = \"Infiltracion\"\n","            explicacion_extra = \"\\n\\n⚠️ EL PULMÓN NO ESTÁ SANO. Deberías visitar a tu médico.\"\n","        else:\n","            resultado_texto = \"Sano\"\n","            explicacion_extra = \"\"\n","\n","        # D. Formato para Gradio Label (%)\n","        confidencias = {\n","            \"Infiltracion\": float(prob_infil),\n","            \"Sano\": float(prob_sano)\n","        }\n","\n","        # E. Obtener explicación del LLM\n","        # Usamos la función que ya tenías para el texto de la enfermedad\n","        explicacion_base = obtener_explicacion_llm(resultado_texto)\n","\n","        # F. Informe final con la advertencia médica\n","        informe = (\n","            f\"DIAGNÓSTICO CNN: {resultado_texto.upper()}\\n\"\n","            f\"PROBABILIDAD DE INFILTRACIÓN: {prob_infil*100:.2f}%\\n\"\n","            f\"----------------------------------------\\n\"\n","            f\"DETALLES: {explicacion_base}\"\n","            f\"{explicacion_extra}\" # Aquí se añade el mensaje si > 30%\n","        )\n","\n","        return img_final, confidencias, informe\n","\n","    except Exception as e:\n","        return img_input, {}, f\"❌ Error: {str(e)}\"\n","\n","# ==========================================\n","# 4. INTERFAZ GRADIO\n","# ==========================================\n","\n","with gr.Blocks(theme=gr.themes.Soft(primary_hue=\"cyan\")) as demo:\n","    gr.HTML(\"<h1 style='text-align: center; color: #0891b2;'>🏥 Sistema Predictor de Infiltración</h1>\")\n","\n","    with gr.Row():\n","        with gr.Column():\n","            id_input = gr.Textbox(label=\"ID Paciente\")\n","            img_input = gr.Image(label=\"Radiografía\", type=\"pil\")\n","            url_input = gr.Textbox(label=\"URL Imagen\")\n","            btn = gr.Button(\"🚀 EJECUTAR PREDICCIÓN\", variant=\"primary\")\n","\n","        with gr.Column():\n","            label_out = gr.Label(num_top_classes=2, label=\"Probabilidad Real CNN\")\n","            text_out = gr.Textbox(label=\"Informe y Detalles\", lines=10)\n","\n","    btn.click(\n","        fn=motor_prediccion,\n","        inputs=[img_input, id_input, url_input],\n","        outputs=[img_input, label_out, text_out]\n","    )\n","\n","if __name__ == \"__main__\":\n","    demo.launch(share=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":626},"id":"eK9OWIfzj11Z","executionInfo":{"status":"ok","timestamp":1774554764496,"user_tz":-60,"elapsed":2144,"user":{"displayName":"David Arenas","userId":"06929154522958225556"}},"outputId":"d825931d-42f6-4bfc-94d4-ee0228e9fe67"},"execution_count":25,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_3918/1874996376.py:96: DeprecationWarning: The 'theme' parameter in the Blocks constructor will be removed in Gradio 6.0. You will need to pass 'theme' to Blocks.launch() instead.\n","  with gr.Blocks(theme=gr.themes.Soft(primary_hue=\"cyan\")) as demo:\n"]},{"output_type":"stream","name":"stdout","text":["Colab notebook detected. To show errors in colab notebook, set debug=True in launch()\n","* Running on public URL: https://0ad96ff59ae65878e1.gradio.live\n","\n","This share link expires in 1 week. For free permanent hosting and GPU upgrades, run `gradio deploy` from the terminal in the working directory to deploy to Hugging Face Spaces (https://huggingface.co/spaces)\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["<div><iframe src=\"https://0ad96ff59ae65878e1.gradio.live\" width=\"100%\" height=\"500\" allow=\"autoplay; camera; microphone; clipboard-read; clipboard-write;\" frameborder=\"0\" allowfullscreen></iframe></div>"]},"metadata":{}}]}]}